<!DOCTYPE html>
<html>
<head>
  <title>Happy Birthday 🎂</title>
  <style>
    body {
      margin: 0;
      background: linear-gradient(to right, #ff6ec4, #7873f5);
      color: white;
      font-family: Arial;
      text-align: center;
    }

    h1 {
      margin-top: 20%;
      font-size: 3em;
      animation: fadeIn 3s ease-in-out;
    }

    button {
      padding: 10px 20px;
      font-size: 18px;
      border: none;
      background: white;
      color: purple;
      cursor: pointer;
      margin-top: 20px;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(50px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body>
  <h1>🎉 Happy Birthday! 🎂</h1>
  <button onclick="showMessage()">Click Me 💖</button>

  <script>
    function showMessage() {
      alert("Wishing you lots of happiness and cake! 🎂💖");
    }
  </script>
</body>
</html>
